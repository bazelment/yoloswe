load("@rules_go//go:def.bzl", "go_binary", "go_library", "go_test")

go_library(
    name = "jiradozer_lib",
    srcs = [
        "bootstrap.go",
        "main.go",
        "run.go",
        "team_signals_other.go",
        "team_signals_unix.go",
        "team_supervisor.go",
        "validate_config.go",
    ],
    importpath = "github.com/bazelment/yoloswe/jiradozer/cmd/jiradozer",
    visibility = ["//visibility:private"],
    deps = [
        "//agent-cli-wrapper/claude/render",
        "//cliapp",
        "//jiradozer",
        "//jiradozer/tracker",
        "//jiradozer/tracker/github",
        "//jiradozer/tracker/linear",
        "//jiradozer/tracker/local",
        "//multiagent/agent",
        "//wt",
        "@com_github_spf13_cobra//:cobra",
    ],
)

go_binary(
    name = "jiradozer",
    embed = [":jiradozer_lib"],
    visibility = ["//visibility:public"],
)

go_test(
    name = "jiradozer_test",
    srcs = [
        "bootstrap_test.go",
        "main_test.go",
    ],
    data = [
        "//jiradozer:jiradozer.example.yaml",
    ],
    embed = [":jiradozer_lib"],
    rundir = ".",
    deps = [
        "//agent-cli-wrapper/claude/render",
        "//cliapp",
        "//jiradozer",
        "//jiradozer/tracker",
        "//jiradozer/tracker/local",
        "@com_github_spf13_cobra//:cobra",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
