load("@rules_go//go:def.bzl", "go_binary", "go_library", "go_test")

go_library(
    name = "jiradozer_lib",
    srcs = ["main.go"],
    importpath = "github.com/bazelment/yoloswe/jiradozer/cmd/jiradozer",
    visibility = ["//visibility:private"],
    deps = [
        "//agent-cli-wrapper/claude/render",
        "//jiradozer",
        "//jiradozer/tracker",
        "//jiradozer/tracker/github",
        "//jiradozer/tracker/linear",
        "//jiradozer/tracker/local",
        "//jiradozer/tui",
        "//logging/klogfmt",
        "//multiagent/agent",
        "//wt",
        "@com_github_spf13_cobra//:cobra",
        "@land_charm_bubbletea_v2//:bubbletea",
    ],
)

go_binary(
    name = "jiradozer",
    embed = [":jiradozer_lib"],
    visibility = ["//visibility:public"],
)

go_test(
    name = "jiradozer_test",
    srcs = ["main_test.go"],
    embed = [":jiradozer_lib"],
    deps = [
        "//jiradozer",
        "//jiradozer/tracker",
        "@com_github_stretchr_testify//assert",
    ],
)
