load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "progress",
    srcs = [
        "console.go",
        "events.go",
        "reporter.go",
    ],
    importpath = "github.com/bazelment/yoloswe/multiagent/progress",
    visibility = ["//visibility:public"],
    deps = [
        "//multiagent/agent",
