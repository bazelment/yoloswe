load("@rules_go//go:def.bzl", "go_binary", "go_library", "go_test")

go_library(
    name = "voicetest_lib",
    srcs = ["main.go"],
    importpath = "github.com/bazelment/yoloswe/voice/cmd/voicetest",
    visibility = ["//visibility:private"],
    deps = [
        "//agent-cli-wrapper/claude/render",
        "//logging/klogfmt",
        "//voice/stt",
        "//voice/stt/deepgram",
        "//voice/stt/logging",
    ],
)

go_binary(
    name = "voicetest",
    embed = [":voicetest_lib"],
    visibility = ["//visibility:public"],
)

go_test(
    name = "voicetest_test",
    srcs = ["main_test.go"],
    embed = [":voicetest_lib"],
    deps = ["//voice/stt"],
)
