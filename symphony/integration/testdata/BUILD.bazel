# gazelle:ignore
load("@rules_go//go:def.bzl", "go_binary", "go_library", "go_test")

go_library(
    name = "testdata_lib",
    srcs = ["fake_codex.go"],
    importpath = "github.com/bazelment/yoloswe/symphony/integration/testdata",
    visibility = ["//visibility:private"],
)

go_binary(
    name = "fake_codex",
    embed = [":testdata_lib"],
    visibility = ["//symphony:__subpackages__"],
)

go_test(
    name = "testdata_test",
    srcs = ["fake_codex_test.go"],
    embed = [":testdata_lib"],
    deps = ["@com_github_stretchr_testify//require"],
)
