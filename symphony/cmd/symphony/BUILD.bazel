load("@rules_go//go:def.bzl", "go_binary", "go_library")

go_library(
    name = "symphony_lib",
    srcs = ["main.go"],
    importpath = "github.com/bazelment/yoloswe/symphony/cmd/symphony",
    visibility = ["//visibility:private"],
    deps = [
        "//symphony/config",
