load("@rules_go//go:def.bzl", "go_binary", "go_library", "go_test")

go_library(
    name = "prdozer_lib",
    srcs = ["main.go"],
    importpath = "github.com/bazelment/yoloswe/prdozer/cmd/prdozer",
    visibility = ["//visibility:private"],
    deps = [
        "//agent-cli-wrapper/claude/render",
        "//logging/klogfmt",
        "//multiagent/agent",
        "//prdozer",
        "//wt",
        "@com_github_spf13_cobra//:cobra",
    ],
)

go_binary(
    name = "prdozer",
    embed = [":prdozer_lib"],
    visibility = ["//visibility:public"],
)

go_test(
    name = "prdozer_test",
    srcs = ["main_test.go"],
    embed = [":prdozer_lib"],
    deps = [
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
